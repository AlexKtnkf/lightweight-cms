{
  "name": "lightweight-cms",
  "version": "1.0.0",
  "description": "Lightweight CMS for personal website",
  "main": "server.js",
  "scripts": {
    "dev": "node server.js",
    "dev:server": "node server.js",
    "dev:admin": "cd admin && npm run dev",
    "build:admin": "cd admin && npm run build",
    "start": "npm run migrate && NODE_ENV=production node server.js",
    "start:railway": "npm run start",
    "migrate": "node db/migrate.js",
    "seed": "node db/seed.js",
    "setup": "npm run migrate && npm run seed",
    "create-admin": "node db/create-admin.js",
    "reset-admin-password": "node db/reset-admin-password.js",
    "generate-static": "node -e \"require('./src/infrastructure/static/staticGenerator').generateAll().then(() => process.exit(0)).catch(err => { console.error(err); process.exit(1); })\""
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "pg": "^8.11.0",
    "dompurify": "^3.0.6",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsdom": "^23.0.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.3",
    "rss": "^1.2.2",
    "sharp": "^0.33.1",
    "uuid": "^9.0.1"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "vite": "^7.2.4"
  }
}
