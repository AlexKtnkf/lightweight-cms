<%
  // Build footer menu
  const footerLinks = [];
  
  // Add footer menu links from settings
  if (settings && settings.footer_menu_links && Array.isArray(settings.footer_menu_links)) {
    footerLinks.push(...settings.footer_menu_links);
  }
  
  // Sort by order
  footerLinks.sort((a, b) => (a.order || 0) - (b.order || 0));
  
  const footerText = settings?.footer_text || `© ${new Date().getFullYear()} ${settings?.site_title || 'My Site'}. Tous droits réservés.`;
%>
<footer role="contentinfo">
  <div class="container">
    <div class="footer-title">
      <% 
      const siteTitle = settings?.site_title || 'My Site';
      const titleWords = siteTitle.split(' ');
      if (titleWords.length > 1) {
      %>
      <span><%= titleWords[0] %><span class="footer-gold-accent"><%= titleWords.slice(1).join(' ') %></span></span>
      <% } else { %>
      <span><%= siteTitle %></span>
      <% } %>
    </div>
    <% if (settings?.footer_text) { %>
    <p class="footer-description"><%= settings.footer_text %></p>
    <% } %>
    
    <% 
    // Filter out links without both label and url
    const validFooterLinks = footerLinks.filter(link => link && link.label && link.url && link.label.trim() && link.url.trim());
    %>
    <% if (validFooterLinks.length > 0) { %>
    <nav class="footer-nav" aria-label="Liens du pied de page">
      <ul>
        <% validFooterLinks.forEach(link => { %>
          <li>
            <a 
              href="<%= link.url %>" 
              class="footer-link"
              <%= link.url.startsWith('http') ? 'target="_blank" rel="noopener noreferrer"' : '' %>
            >
              <%= link.label %>
            </a>
          </li>
        <% }); %>
      </ul>
    </nav>
    <% } %>
    
    <% 
    // Social links from settings (assuming they're stored as an array or object)
    const socialLinks = settings?.social_links || [];
    if (socialLinks.length > 0) {
    %>
    <div class="social-links">
      <% socialLinks.forEach(link => { %>
      <a href="<%= link.url %>" target="_blank" rel="noopener noreferrer" aria-label="<%= link.platform || link.label %>">
        <% if (link.platform === 'instagram' || link.icon === 'instagram') { %>
        <%- include('icons/instagram') %>
        <% } else if (link.platform === 'facebook' || link.icon === 'facebook') { %>
        <%- include('icons/facebook') %>
        <% } else if (link.platform === 'linkedin' || link.icon === 'linkedin') { %>
        <%- include('icons/linkedin') %>
        <% } else if (link.platform === 'tiktok' || link.icon === 'tiktok') { %>
        <%- include('icons/tiktok') %>
        <% } else { %>
        <%= link.label || link.platform %>
        <% } %>
      </a>
      <% }); %>
    </div>
    <% } %>
    <div class="footer-copyright">
      &copy; <%= new Date().getFullYear() %> <%= siteTitle.toUpperCase() %>. ALL RIGHTS RESERVED.
    </div>
  </div>
</footer>
