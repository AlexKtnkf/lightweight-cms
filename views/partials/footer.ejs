<%
  const footerLinks = (settings && settings.footer_menu_links && Array.isArray(settings.footer_menu_links)) ? settings.footer_menu_links : [];
  footerLinks.sort((a, b) => (a.order || 0) - (b.order || 0));
  const siteTitle = settings?.site_title || 'My Site';
  const socialLinks = settings?.social_links || [];
  const currentYear = new Date().getFullYear();
  const footerText = settings?.footer_text || `© ${currentYear} ${siteTitle}. Mentions légales.`;
%>
<footer class="c-footer" role="contentinfo">
  <div class="l-container">
    <% if (socialLinks.length > 0) { %>
    <div class="c-footer__socials">
      <% socialLinks.forEach(link => { %>
      <a href="<%= link.url %>" target="_blank" rel="noopener noreferrer" aria-label="<%= link.platform || link.label %>">
        <% if (link.platform === 'instagram' || link.icon === 'instagram') { %>
        <%- include('icons/instagram') %>
        <% } else if (link.platform === 'facebook' || link.icon === 'facebook') { %>
        <%- include('icons/facebook') %>
        <% } else if (link.platform === 'linkedin' || link.icon === 'linkedin') { %>
        <%- include('icons/linkedin') %>
        <% } else if (link.platform === 'tiktok' || link.icon === 'tiktok') { %>
        <%- include('icons/tiktok') %>
        <% } else { %>
        <%= link.label || link.platform %>
        <% } %>
      </a>
      <% }); %>
    </div>
    <% } %>
    <p class="c-footer__copy" style="font-size: 0.8rem; opacity: 0.6;"><%= footerText %></p>
  </div>
</footer>
