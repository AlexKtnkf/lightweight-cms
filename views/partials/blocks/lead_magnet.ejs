<!--
  Block: Lead Magnet (Email capture)
  Purpose: Centered CTA box with email form (matches c-lead / c-lead__form)
  Expected Data: block.block_data = { icon, title, description, action_url, placeholder, button_text }
-->
<section class="l-container l-section" id="<%= block.id ? 'block-' + block.id : 'lead-magnet' %>">
  <div class="c-lead">
    <% if (block.block_data.icon) { %>
    <div class="c-lead__icon">
      <% if (block.block_data.icon === 'seedling') { %>
      <%- include('../icons/seedling') %>
      <% } else { %>
      <i class="<%= block.block_data.icon %>" aria-hidden="true"></i>
      <% } %>
    </div>
    <% } %>
    <% if (block.block_data.title) { %>
    <h3 class="c-lead__title"><%= block.block_data.title %></h3>
    <% } %>
    <% if (block.block_data.description) { %>
    <p class="c-lead__description"><%= block.block_data.description %></p>
    <% } %>
    <form class="c-lead__form" method="POST" action="<%= block.block_data.action_url || '#' %>">
      <input type="email" name="email" placeholder="<%= block.block_data.placeholder || 'Votre email' %>" required>
      <button type="submit" class="btn btn--primary"><%= block.block_data.button_text || 'S\'inscrire' %></button>
    </form>
  </div>
</section>
