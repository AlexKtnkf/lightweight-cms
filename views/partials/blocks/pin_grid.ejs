<!--
  Block: Pin Grid (Instagram-style gallery)
  Purpose: Horizontal scroll on mobile, 3-column grid on desktop (matches c-pin-grid)
  Expected Data: block.block_data = { section_title, pins: [{ image_media_id, label }] }
-->
<% if (block.block_data.pins && block.block_data.pins.length > 0) { %>
<section class="l-section" id="<%= block.id ? 'block-' + block.id : 'pin-grid' %>">
  <div class="l-container">
    <% if (block.block_data.section_title) { %>
    <h2 class="c-headline__title" style="text-align: center; margin-bottom: 3rem;"><%= block.block_data.section_title %></h2>
    <% } %>
    <div class="c-pin-grid">
    <% block.block_data.pins.forEach((pin) => { %>
    <figure class="c-pin-grid__item">
      <% if (pin.image_media_id) { %>
      <img src="/api/media/<%= pin.image_media_id %>" alt="<%= pin.label || 'Image' %>" loading="lazy">
      <% } %>
      <% if (pin.label) { %>
      <figcaption><%= pin.label %></figcaption>
      <% } %>
    </figure>
    <% }); %>
    </div>
  </div>
</section>
<% } %>
