<header class="c-hero l-full-page" aria-labelledby="hero-title-<%= block.id || 'default' %>">
  <div class="l-container">
    <div class="c-hero__content">
      <% if (block.block_data.tagline) { %>
      <span class="c-hero__tag"><%= block.block_data.tagline %></span>
      <% } %>
      <h1 id="hero-title-<%= block.id || 'default' %>" class="c-hero__title">
        <%= (block.block_data.textePrincipal || block.block_data.title || '').split('\n').join(' ') %>
      </h1>
      <% if (block.block_data.sousTexte || block.block_data.description) { %>
      <p><%= block.block_data.sousTexte || block.block_data.description || '' %></p>
      <% } %>
      <div class="c-hero__actions">
        <% if (block.block_data.texteBoutonPrincipal || block.block_data.button_primary_text) { %>
        <a href="<%= block.block_data.urlBoutonPrincipal || block.block_data.button_primary_url || '#' %>" class="btn btn--primary"><%= block.block_data.texteBoutonPrincipal || block.block_data.button_primary_text %></a>
        <% } %>
        <% if (block.block_data.texteBoutonSecondaire || block.block_data.button_secondary_text) { %>
        <a href="<%= block.block_data.urlBoutonSecondaire || block.block_data.button_secondary_url || '#' %>" class="btn btn--outline"><%= block.block_data.texteBoutonSecondaire || block.block_data.button_secondary_text %></a>
        <% } %>
      </div>
    </div>
  </div>
</header>
