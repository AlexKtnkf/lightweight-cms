<% if (block.block_data.cards && block.block_data.cards.length > 0) { %>
<section class="l-section" id="<%= block.id ? 'block-' + block.id : 'numbered-cards' %>">
  <div class="l-container">
    <% if (block.block_data.section_title) { %>
    <div class="c-section-intro c-section-intro--center">
      <h2 class="c-headline__title section-title centered"><%= block.block_data.section_title %></h2>
    </div>
    <% } %>
    <div class="c-num-grid">
    <% block.block_data.cards.forEach((card, index) => { %>
    <div class="c-num-card">
      <span class="c-num-card__number"><%= String(card.number != null ? card.number : index + 1).padStart(2, '0') %></span>
      <% if (card.title) { %>
      <h3 class="c-num-card__title"><%= card.title %></h3>
      <% } %>
      <% if (card.description) { %>
      <p><%- card.description %></p>
      <% } %>
    </div>
    <% }); %>
    </div>
  </div>
</section>
<% } %>
