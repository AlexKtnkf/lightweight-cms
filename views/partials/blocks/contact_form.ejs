<% if (block.block_data.fields && block.block_data.fields.length > 0) { %>
<section id="contact" class="section-padding container">
  <div style="text-align: center; margin-bottom: 4rem;">
    <% if (block.block_data.title) { %>
    <h2><%= block.block_data.title %></h2>
    <% } %>
    <% if (block.block_data.description) { %>
    <p style="color: var(--text-muted);"><%= block.block_data.description %></p>
    <% } %>
  </div>
  <form class="contact-form" method="POST" action="#">
    <% block.block_data.fields.forEach((field, index) => { %>
      <% if (field.type === 'textarea') { %>
      <div>
        <label class="label-style"><%= field.label %><% if (field.required) { %> *<% } %></label>
        <textarea 
          name="field_<%= index %>" 
          class="input-field" 
          rows="4" 
          placeholder="<%= field.placeholder || '' %>"
          <% if (field.required) { %>required<% } %>
          style="resize: none;"
        ></textarea>
      </div>
      <% } else if (field.type === 'select') { %>
      <div>
        <label class="label-style"><%= field.label %><% if (field.required) { %> *<% } %></label>
        <select 
          name="field_<%= index %>" 
          class="input-field"
          <% if (field.required) { %>required<% } %>
        >
          <option value=""><%= field.placeholder || 'Select...' %></option>
        </select>
      </div>
      <% } else { %>
      <div>
        <label class="label-style"><%= field.label %><% if (field.required) { %> *<% } %></label>
        <input 
          type="<%= field.type || 'text' %>" 
          name="field_<%= index %>" 
          class="input-field" 
          placeholder="<%= field.placeholder || '' %>"
          <% if (field.required) { %>required<% } %>
        >
      </div>
      <% } %>
    <% }); %>
    <button type="submit" class="btn btn-green">
      <%= block.block_data.submit_button_text || 'Submit Application' %>
    </button>
  </form>
</section>
<% } %>
