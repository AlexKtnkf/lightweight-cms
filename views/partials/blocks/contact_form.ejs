<!--
  Block: Contact Form
  Purpose: Form with dynamic fields (matches c-contact / c-contact__form / c-contact__group)
  Expected Data: block.block_data = { title, description, fields: [{ type, label, placeholder, required, options }], submit_button_text, action_url }
-->
<% if (block.block_data.fields && block.block_data.fields.length > 0) { %>
<section id="contact" class="l-container l-section">
  <div class="c-contact">
    <% if (block.block_data.title) { %>
    <h2 class="c-headline__title" style="text-align: center;"><%= block.block_data.title %></h2>
    <% } %>
    <% if (block.block_data.description) { %>
    <p class="c-contact__description"><%= block.block_data.description %></p>
    <% } %>
    <form class="c-contact__form" method="POST" action="<%= block.block_data.action_url || '#' %>">
      <%
      const fields = block.block_data.fields;
      fields.forEach((field, index) => {
        const isFullWidth = field.type === 'textarea' || field.type === 'select';
      %>
      <div class="c-contact__group<%= isFullWidth ? ' c-contact__group--full' : '' %>">
        <label for="contact-field-<%= index %>"><%= field.label %><% if (field.required) { %> *<% } %></label>
        <% if (field.type === 'textarea') { %>
        <textarea id="contact-field-<%= index %>" name="field_<%= index %>" rows="5" placeholder="<%= field.placeholder || '' %>" <%= field.required ? 'required' : '' %>></textarea>
        <% } else if (field.type === 'select') { %>
        <select id="contact-field-<%= index %>" name="field_<%= index %>" <%= field.required ? 'required' : '' %>>
          <option value=""><%= field.placeholder || 'Choisir...' %></option>
          <% if (field.options && Array.isArray(field.options)) { field.options.forEach(opt => { %>
          <option value="<%= opt.value || opt %>"><%= opt.label || opt %></option>
          <% }); } %>
        </select>
        <% } else { %>
        <input type="<%= field.type || 'text' %>" id="contact-field-<%= index %>" name="field_<%= index %>" placeholder="<%= field.placeholder || '' %>" <%= field.required ? 'required' : '' %>>
        <% } %>
      </div>
      <% }); %>
      <div class="c-contact__group c-contact__group--full">
        <button type="submit" class="btn btn--primary"><%= block.block_data.submit_button_text || 'Envoyer' %></button>
      </div>
    </form>
  </div>
</section>
<% } %>
