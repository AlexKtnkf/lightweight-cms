<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Blog - <%= settings?.site_title || 'My Site' %></title>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <% if (typeof jsonLd !== 'undefined' && jsonLd && jsonLd.length > 0) { %>
  <% jsonLd.forEach(schema => { %>
  <script type="application/ld+json"><%= JSON.stringify(schema, null, 2) %></script>
  <% }); %>
  <% } %>
  <link rel="stylesheet" href="/css/main.css">
  <% if (gaId) { %>
  <script async src="https://www.googletagmanager.com/gtag/js?id=<%= gaId %>"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '<%= gaId %>');
  </script>
  <% } %>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js"></script>
</head>
<body>
  <a href="#main-content" class="skip-link">Aller au contenu principal</a>
  
  <%- include('../partials/navbar') %>

  <main id="main-content" class="l-section c-blog-page">
    <div class="l-container">
      <section class="c-blog-hero">
        <div>
          <h1 class="c-blog-hero__title">Blog</h1>
        </div>
      </section>

      <% if (articles.length > 0) { %>
      <div class="c-blog-list">
        <% articles.forEach((article, index) => { %>
        <article class="c-blog-card">
          <div class="c-blog-card__meta">
            <time datetime="<%= article.published_at || article.created_at %>">
              <%= new Date(article.published_at || article.created_at).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }) %>
            </time>
          </div>
          <div class="c-blog-card__content">
            <h2 class="c-blog-card__title">
              <a href="/blog/<%= article.slug %>"><%= article.title %></a>
            </h2>
            <% if (article.excerpt) { %>
            <p class="c-blog-card__excerpt"><%= article.excerpt %></p>
            <% } %>
            <a href="/blog/<%= article.slug %>" class="c-blog-card__link">Lire la suite</a>
          </div>
        </article>
        <% }); %>
      </div>
      <% } else { %>
      <section class="c-blog-empty">
        <h2>Aucun article pour le moment</h2>
        <p>Le blog arrive bientôt. Revenez un peu plus tard pour découvrir les premiers contenus.</p>
      </section>
      <% } %>
    </div>
  </main>

  <%- include('../partials/footer', { settings }) %>

  <script src="/js/main.js"></script>
</body>
</html>
