<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Blog - <%= settings?.site_title || 'My Site' %></title>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <% if (typeof jsonLd !== 'undefined' && jsonLd && jsonLd.length > 0) { %>
  <% jsonLd.forEach(schema => { %>
  <script type="application/ld+json"><%= JSON.stringify(schema, null, 2) %></script>
  <% }); %>
  <% } %>
  <link rel="stylesheet" href="/css/main.css">
  <% if (gaId) { %>
  <script async src="https://www.googletagmanager.com/gtag/js?id=<%= gaId %>"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '<%= gaId %>');
  </script>
  <% } %>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js"></script>
</head>
<body>
  <a href="#main-content" class="skip-link">Aller au contenu principal</a>
  
  <%- include('../partials/navbar') %>

  <main id="main-content" class="container">
    <h1>Blog</h1>
    <div class="articles-list">
      <% articles.forEach(article => { %>
      <article class="article-preview">
        <h2><a href="/blog/<%= article.slug %>"><%= article.title %></a></h2>
        <time><%= new Date(article.published_at || article.created_at).toLocaleDateString('fr-FR') %></time>
        <% if (article.meta_description) { %>
        <p><%= article.meta_description %></p>
        <% } %>
        <a href="/blog/<%= article.slug %>" class="read-more">Lire la suite →</a>
      </article>
      <% }); %>
    </div>
  </main>

  <%- include('../partials/footer', { settings }) %>

  <script src="/js/main.js"></script>
</body>
</html>
