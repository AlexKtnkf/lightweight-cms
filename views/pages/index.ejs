<%
  const siteTitle = settings?.site_title || 'My Site';
  const title = homepage.meta_title || homepage.title || siteTitle;
  const metaDescription = homepage.meta_description || settings?.site_tagline || '';
  const ogTitle = homepage.og_title || homepage.meta_title || homepage.title || siteTitle;
  const ogDescription = homepage.og_description || homepage.meta_description || metaDescription;
%>
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="<%= metaDescription %>">
  <meta property="og:title" content="<%= ogTitle %>">
  <meta property="og:description" content="<%= ogDescription %>">
  <meta property="og:type" content="website">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <% if (typeof jsonLd !== 'undefined' && jsonLd && jsonLd.length > 0) { %>
  <% jsonLd.forEach(schema => { %>
  <script type="application/ld+json"><%= JSON.stringify(schema, null, 2) %></script>
  <% }); %>
  <% } %>
  <link rel="stylesheet" href="/css/main.css">
  <% if (gaId) { %>
  <script async src="https://www.googletagmanager.com/gtag/js?id=<%= gaId %>"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '<%= gaId %>');
  </script>
  <% } %>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head>
<body>
  <!-- Skip to main content link for screen readers -->
  <a href="#main-content" class="skip-link">Aller au contenu principal</a>
  
  <%- include('../partials/navbar', { settings, pages }) %>

  <main id="main-content">
    <% 
    // Find hero block if it exists
    const heroBlock = homepage.blocks?.find(b => b.block_type === 'hero');
    %>
    <% if (heroBlock) { %>
      <%- include('../partials/blocks/hero', { block: heroBlock, settings, baseUrl }) %>
    <% } else { %>
    <section class="hero" aria-labelledby="hero-title">
      <div class="container">
        <% if (settings?.logo_media_id) { %>
        <img src="/api/media/<%= settings.logo_media_id %>" alt="Logo <%= siteTitle %>" class="hero-logo">
        <% } else { %>
        <img src="/android-chrome-512x512.png" alt="Logo <%= siteTitle %>" class="hero-logo">
        <% } %>
        <div class="hero-content">
          <h1 id="hero-title"><%= homepage.title || siteTitle %></h1>
          <p class="hero-subtitle"><%= homepage.meta_description || settings?.site_tagline || 'Diététicienne-Nutritionniste' %></p>
        </div>
      </div>
      <div class="waves">
        <svg class="waves" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 24 150 28" preserveAspectRatio="none" style="height: 60px; width: 100%;">
          <defs>
            <path id="gentle-wave" d="M-160 44c30 0 58-18 88-18s 58 18 88 18 58-18 88-18 58 18 88 18 v44h-352z" />
          </defs>
          <g class="parallax">
            <use xlink:href="#gentle-wave" x="48" y="0" fill="rgba(34, 181, 115, 0.3)" />
            <use xlink:href="#gentle-wave" x="48" y="3" fill="rgba(34, 181, 115, 0.2)" />
            <use xlink:href="#gentle-wave" x="48" y="5" fill="rgba(34, 181, 115, 0.1)" />
            <use xlink:href="#gentle-wave" x="48" y="7" fill="#FFFFFF" />
          </g>
        </svg>
      </div>
    </section>
    <% } %>

    <% if (homepage.blocks && homepage.blocks.length > 0) { %>
      <% homepage.blocks.forEach((block) => { %>
        <% 
        // Skip hero block if we already rendered it above
        if (block.block_type === 'hero' && heroBlock) {
          return;
        }
        // Use try-catch to handle missing block types gracefully
        try {
          const blockPartial = '../partials/blocks/' + block.block_type;
        %>
        <%- include(blockPartial, { block, settings, baseUrl }) %>
        <% } catch (e) { %>
        <!-- Block type <%= block.block_type %> not found -->
        <% } %>
      <% }); %>
    <% } %>
  </main>

  <%- include('../partials/footer', { settings }) %>

  <script src="/js/main.js"></script>
</body>
</html>
