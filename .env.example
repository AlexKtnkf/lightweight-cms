# Server Configuration
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
# Local dev: start Postgres with `docker compose up -d` then use the default below.
# Railway: the DATABASE_URL variable is set automatically by the Postgres plugin.
DATABASE_URL=postgres://cms:cms_dev_password@localhost:5432/lightweight_cms

# Upload storage path (for Railway volumes, set to e.g. /data/uploads)
# This directory should contain an "images" subfolder used by the media pipeline.
UPLOADS_DIR=./public/uploads

# Security
SESSION_SECRET=change-this-secret-key-in-production
# Set to 'true' when behind HTTPS in production
FORCE_HTTPS=false

# Setup token for initial admin creation or emergency password reset
# Generate with: openssl rand -base64 32
# Only needed during setup; can be removed after first admin is created
SETUP_TOKEN=your-secure-setup-token-here

# Password hashing (higher = slower but more secure, default 12)
# BCRYPT_ROUNDS=12

# Site Configuration
SITE_HOST=localhost:3000

# Email Configuration (Contact Form)
# Example for Gmail: use App Passwords (not regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# Email recipient for contact forms
CONTACT_EMAIL_TO=admin@example.com
CONTACT_EMAIL_FROM=noreply@example.com
CONTACT_EMAIL_FROM_NAME=Contact Form

# Send confirmation email to visitor (true/false)
SEND_CONFIRMATION_EMAIL=true

# Cloudflare Turnstile (bot protection for contact form)
# Get keys from https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

