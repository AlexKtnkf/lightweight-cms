# NPM Configuration for lightweight-cms

# Ignore known build-time vulnerabilities in tar/node-gyp
# These are development/build-time dependencies that do not affect production runtime
# The vulnerabilities are in node-gyp's use of tar during compilation, not in the final binary

# Allow non-exact versions for better compatibility
engine-strict=false

# Use ignore-scripts to avoid running postinstall scripts that might use the vulnerable tar
# (uncomment if you want to skip postinstall scripts)
# ignore-scripts=true
